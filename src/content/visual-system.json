{
  "concept": {
    "direction": "Warm editorial modernism with precise technical restraint",
    "keywords": ["warm", "clean", "layered", "premium", "controlled", "professional"]
  },
  "typography": {
    "display": {
      "family": "\"Space Grotesk\", \"Azeret Mono\", sans-serif",
      "use": "Hero headlines, project titles, key numeric statements"
    },
    "body": {
      "family": "\"Manrope\", \"Inter\", sans-serif",
      "use": "Body copy, navigation, supporting text"
    },
    "accent": {
      "family": "\"IBM Plex Mono\", monospace",
      "use": "Metadata, labels, metrics, small UI hints"
    },
    "scale": {
      "hero": "clamp(3rem, 9vw, 8.5rem)",
      "h1": "clamp(2rem, 6vw, 4.2rem)",
      "h2": "clamp(1.75rem, 4vw, 3rem)",
      "h3": "1.15rem",
      "body": "1.0625rem",
      "small": "0.9rem",
      "meta": "0.7rem"
    }
  },
  "spacing": {
    "baseUnit": 8,
    "sectionPadding": "clamp(5rem, 10vw, 10rem)",
    "contentWidth": "min(1180px, calc(100vw - 3rem))",
    "rhythm": ["0.4rem", "0.8rem", "1.2rem", "1.6rem", "2.4rem", "3.2rem", "4.8rem", "6.4rem"]
  },
  "colors": {
    "background": "#F3EADF",
    "surface": "#EFE1D1",
    "surfaceStrong": "#E1CFBD",
    "text": "#123B45",
    "textSoft": "#2F5D66",
    "line": "rgba(18, 59, 69, 0.14)",
    "shadow": "rgba(15, 36, 48, 0.16)",
    "palette": {
      "midnight": "#0F414A",
      "deepTeal": "#1C5C54",
      "seaBlue": "#3C7792",
      "lightBlue": "#96C0CE",
      "alabaster": "#EFE8DF",
      "tan": "#D8BA98",
      "ochre": "#E1A41A",
      "amber": "#FFB01F",
      "orange": "#E56626",
      "rust": "#A22710",
      "maroon": "#7F0303",
      "violet": "#6A2C91",
      "plum": "#912065",
      "softLilac": "#B18AD1"
    },
    "usage": {
      "primary": "#0F414A",
      "secondary": "#D8BA98",
      "accentWarm": "#E56626",
      "accentCool": "#96C0CE",
      "accentViolet": "#6A2C91",
      "accentDeep": "#7F0303"
    },
    "gradients": {
      "heroWash": "linear-gradient(135deg, rgba(239, 232, 223, 0.96) 0%, rgba(216, 186, 152, 0.82) 28%, rgba(150, 192, 206, 0.5) 58%, rgba(177, 138, 209, 0.34) 100%)",
      "cardGlow": "linear-gradient(140deg, rgba(255, 176, 31, 0.26), rgba(150, 192, 206, 0.12) 55%, rgba(106, 44, 145, 0.18) 100%)"
    }
  },
  "motion": {
    "principle": "Motion should feel calm and deliberate, like polished hardware UI rather than playful web decoration.",
    "durations": {
      "fast": "160ms",
      "base": "260ms",
      "slow": "420ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.22, 1, 0.36, 1)",
      "soft": "cubic-bezier(0.2, 0.8, 0.2, 1)"
    },
    "patterns": [
      "Fade and rise for section reveals",
      "Subtle scale and shadow shift on cards",
      "Horizontal media drift on scroll, kept under 12px",
      "Soft highlight sweep for active project media"
    ]
  },
  "components": {
    "cards": {
      "surface": "Rounded 28px corners, warm surface background, thin dark line, soft shadow",
      "hover": "Lift 4px with deeper shadow and a restrained accent glow",
      "content": "Large title, short copy, compact metadata row, media block with generous padding"
    },
    "media": {
      "shape": "Large rounded rectangle with occasional asymmetric crop inside the image frame",
      "treatment": "Use subtle grain or texture overlays sparingly to avoid a too-flat digital look",
      "ratioSuggestions": ["16:10 for hero media", "4:3 for gallery stills", "9:16 optional for mobile demo clips"]
    }
  }
}
